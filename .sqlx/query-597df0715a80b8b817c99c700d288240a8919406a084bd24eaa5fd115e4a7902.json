{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT DISTINCT ON (source_work_item_id)\n                run_id,\n                source_provider,\n                source_organization,\n                source_project,\n                source_work_item_id,\n                target_provider,\n                target_organization,\n                target_project,\n                target_repo_name,\n                target_default_branch,\n                created_by_user_id,\n                created_by_display_name,\n                last_status,\n                draft_pr_url,\n                run_created_at,\n                run_updated_at,\n                last_synced_at\n            FROM agent_run_work_items\n            WHERE source_provider = $1\n              AND source_organization = $2\n              AND source_project = $3\n              AND source_work_item_id = ANY($4)\n            ORDER BY source_work_item_id, run_created_at DESC\n            ",
